            delta +
            '<span class="t-dose-tag">' + r.dose + ' mg</span>' +
          '</div>' +
          (metaParts.length ? '<p class="t-meta">' + metaParts.join(' · ') + '</p>' : '') +
          sideTags +
        '</div>' +
        '<div class="t-actions">' +
          '<button class="t-edit" data-rid="' + r.id + '">' + ICONS.pencil + '</button>' +
