var sheetOverlay = document.getElementById('sheet-overlay');
var selectedSite = null;
var selectedSides = [];
var editingRegistroId = null;

document.getElementById('btn-abrir-sheet').onclick = function() {
  editingRegistroId = null;
  document.querySelector('#sheet-overlay .sheet-title').textContent = 'Registrar aplicação';
  document.getElementById('btn-salvar').textContent = 'Salvar aplicação';
  document.getElementById('input-data').valueAsDate = new Date();
  document.getElementById('input-peso').value = '';
  document.getElementById('input-nota').value = '';
  selectedSite = null;
  selectedSides = [];
  document.querySelectorAll('.site-btn').forEach(function(b) { b.classList.remove('active'); });
  document.querySelectorAll('.chip').forEach(function(b) { b.classList.remove('active'); });
  sheetOverlay.classList.add('visible');
};

function abrirSheetAplicacaoParaEdicao(reg) {
  editingRegistroId = reg.id;
  document.querySelector('#sheet-overlay .sheet-title').textContent = 'Editar aplicação';
  document.getElementById('btn-salvar').textContent = 'Salvar alterações';
  document.getElementById('input-data').value = reg.data;
  document.getElementById('input-dose').value = reg.dose;
  document.getElementById('input-peso').value = typeof reg.peso === 'number' ? reg.peso : '';
  document.getElementById('input-nota').value = reg.nota || '';
  selectedSite = reg.site || null;
  selectedSides = reg.sideEffects ? reg.sideEffects.slice() : [];
  document.querySelectorAll('.site-btn').forEach(function(b) {
    b.classList.toggle('active', b.getAttribute('data-site') === selectedSite);
  });
  document.querySelectorAll('.chip').forEach(function(b) {
    b.classList.toggle('active', selectedSides.indexOf(b.getAttribute('data-side')) > -1);
  });
  sheetOverlay.classList.add('visible');
}

document.getElementById('btn-cancelar').onclick = function() { sheetOverlay.classList.remove('visible'); };
sheetOverlay.onclick = function(e) { if (e.target === sheetOverlay) sheetOverlay.classList.remove('visible'); };

document.querySelectorAll('.site-btn').forEach(function(btn) {
  btn.onclick = function() {
    var wasActive = this.classList.contains('active');
    document.querySelectorAll('.site-btn').forEach(function(b) { b.classList.remove('active'); });
    if (!wasActive) { this.classList.add('active'); selectedSite = this.getAttribute('data-site'); }
    else { selectedSite = null; }
  };
});
document.querySelectorAll('.chip').forEach(function(chip) {
  chip.onclick = function() {
    var side = this.getAttribute('data-side');
    var idx = selectedSides.indexOf(side);
    if (idx > -1) { selectedSides.splice(idx, 1); this.classList.remove('active'); }
    else { selectedSides.push(side); this.classList.add('active'); }
  };
});

document.getElementById('btn-salvar').onclick = function() {
  var data = document.getElementById('input-data').value;
  var dose = document.getElementById('input-dose').value;
  var pesoRaw = document.getElementById('input-peso').value;
  var nota = document.getElementById('input-nota').value.trim();
  if (!data || !dose) return;

  var registros = getRegistros();

  if (editingRegistroId) {
    var idx = registros.findIndex(function(r) { return r.id === editingRegistroId; });
    if (idx > -1) {
      var atual = registros[idx];
      var atualizado = { id: atual.id, data: data, dose: dose };
      if (pesoRaw) atualizado.peso = parseFloat(pesoRaw);
      if (selectedSite) atualizado.site = selectedSite;
      if (selectedSides.length) atualizado.sideEffects = selectedSides.slice();
      if (nota) atualizado.nota = nota;
      registros[idx] = atualizado;
      saveRegistros(registros);
      showToast('Aplicação atualizada');
    }
  } else {
    var registro = { id: Date.now().toString(), data: data, dose: dose };
    if (pesoRaw) registro.peso = parseFloat(pesoRaw);
    if (selectedSite) registro.site = selectedSite;
    if (selectedSides.length) registro.sideEffects = selectedSides.slice();
    if (nota) registro.nota = nota;
    registros.push(registro);
    saveRegistros(registros);
    showToast('Aplicação registrada');
  }

  editingRegistroId = null;
  sheetOverlay.classList.remove('visible');
  renderRemedioPage();
  renderHomePage();
};

/* ============ INIT ============ */
renderHomePage();
