      renderHomePage();
    };
  }
}

function getWeekKey() {
  var d = new Date();
  var onejan = new Date(d.getFullYear(), 0, 1);
  var week = Math.ceil((((d - onejan) / 86400000) + onejan.getDay() + 1) / 7);
  return d.getFullYear() + '-w' + week;
}

function getNextDoseInfo(registrosSorted) {
  if (registrosSorted.length === 0) return { label: '—', sub: 'sem registros ainda', urgent: false };
  var last = registrosSorted[registrosSorted.length - 1];
  var lastDate = last.data;
  var next = new Date(lastDate);
  next.setDate(next.getDate() + 7);
  var nextIso = next.toISOString().slice(0, 10);
  var diff = daysBetween(isoToday(), nextIso);
  if (diff < 0) return { label: 'atrasada', sub: Math.abs(diff) + ' dia(s) após o previsto', urgent: true };
  if (diff === 0) return { label: 'hoje', sub: formatDateBR(nextIso), urgent: true };
  if (diff === 1) return { label: 'amanhã', sub: formatDateBR(nextIso), urgent: false };
  return { label: 'em ' + diff + 'd', sub: formatDateBR(nextIso), urgent: false };
}

/* ============ TREINO PAGE ============ */
var DAY_ID_TO_WEEKDAY = { seg: 1, ter: 2, qua: 3, qui: 4, sex: 5 };
var activeDay = todayDayId() || 'seg';

function weekStartDate() {
  var d = new Date();
  var sunday = new Date(d.getFullYear(), d.getMonth(), d.getDate() - d.getDay());
  return sunday;
}
function dateForDayId(dayId) {
  var sunday = weekStartDate();
  var dt = new Date(sunday.getFullYear(), sunday.getMonth(), sunday.getDate() + DAY_ID_TO_WEEKDAY[dayId]);
  return isoDate(dt);
}

function renderWeekOverview() {
  var logs = getLogs();
  var wk = getWeekKey();
  var weekLog = logs[wk] || {};
  var el = document.getElementById('week-overview');
  el.innerHTML = DAYS.map(function(d) {
