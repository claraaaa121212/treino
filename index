      document.getElementById('treino-tab-plano').style.display = tab === 'plano' ? '' : 'none';
      document.getElementById('treino-tab-historico').style.display = tab === 'historico' ? '' : 'none';
      if (tab === 'historico') renderHistoricoTreino();
    };
  });
}

function computeTreinoStats(sessions) {
  var now = new Date();
  var wkStart = weekStartDate();
  var wkEnd = new Date(wkStart.getFullYear(), wkStart.getMonth(), wkStart.getDate() + 6);
  var monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
  var sessionDates = {};
  sessions.forEach(function(s) { sessionDates[s.data] = (sessionDates[s.data] || 0) + 1; });

  var weekCount = 0, monthCount = 0;
  sessions.forEach(function(s) {
    var d = new Date(s.data + 'T00:00:00');
    if (d >= wkStart && d <= wkEnd) weekCount++;
    if (d >= monthStart) monthCount++;
  });

  var streak = 0, first = true, guard = 0;
  var cursor = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  while (guard < 1000) {
    guard++;
    var wd = cursor.getDay();
    var iso = isoDate(cursor);
    if (wd === 0 || wd === 6) { cursor.setDate(cursor.getDate() - 1); first = false; continue; }
    if (sessionDates[iso]) { streak++; cursor.setDate(cursor.getDate() - 1); first = false; continue; }
    if (first) { cursor.setDate(cursor.getDate() - 1); first = false; continue; }
    break;
  }
  return { weekCount: weekCount, monthCount: monthCount, streak: streak, total: sessions.length };
}

var calViewDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
var calSelectedDate = null;
var MONTH_NAMES = ['janeiro','fevereiro','março','abril','maio','junho','julho','agosto','setembro','outubro','novembro','dezembro'];
var DOW_SHORT = ['D','S','T','Q','Q','S','S'];

function renderCalendar() {
  var sessions = getSessions();
  var byDate = {};
  sessions.forEach(function(s) { (byDate[s.data] = byDate[s.data] || []).push(s); });
  var cheatDays = getCheatDays();

  document.getElementById('cal-title').textContent = MONTH_NAMES[calViewDate.getMonth()] + ' de ' + calViewDate.getFullYear();

  var year = calViewDate.getFullYear(), month = calViewDate.getMonth();
  var firstDow = new Date(year, month, 1).getDay();
  var daysInMonth = new Date(year, month + 1, 0).getDate();
  var todayIso = isoToday();

  var cells = '';
  DOW_SHORT.forEach(function(d) { cells += '<div class="cal-dow">' + d + '</div>'; });
  for (var e = 0; e < firstDow; e++) cells += '<div class="cal-cell empty"></div>';
  for (var day = 1; day <= daysInMonth; day++) {
    var dt = new Date(year, month, day);
    var iso = isoDate(dt);
    var classes = 'cal-cell';
    if (byDate[iso]) classes += ' has-session';
    if (iso === todayIso) classes += ' today';
    if (iso === calSelectedDate) classes += ' selected';
    if (cheatDays.indexOf(dt.getDay()) > -1) classes += ' cheat';
    cells += '<button class="' + classes + '" data-iso="' + iso + '">' + day + '</button>';
  }
  document.getElementById('cal-grid').innerHTML = cells;

  document.querySelectorAll('#cal-grid .cal-cell:not(.empty)').forEach(function(cell) {
    cell.onclick = function() {
      var iso = this.getAttribute('data-iso');
      calSelectedDate = (calSelectedDate === iso) ? null : iso;
      renderCalendar();
      renderCalDayPanel();
    };
  });
}

function renderCalDayPanel() {
  var panel = document.getElementById('cal-day-panel');
  if (!calSelectedDate) { panel.innerHTML = ''; return; }
