<script>
/* =====================================================================
   HISTÓRICO DE TREINOS
===================================================================== */
function renderTreinoTabs() {
  var tabs = document.querySelectorAll('#treino-tabs button');
  tabs.forEach(function(btn) {
    btn.onclick = function() {
      tabs.forEach(function(b) { b.classList.remove('active'); });
