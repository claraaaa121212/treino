/* ============ REMÉDIO PAGE ============ */
var showAllHistory = false;

function drawChart(registros) {
  var canvas = document.getElementById('chart');
  var wrap = canvas.parentElement;
  var dpr = window.devicePixelRatio || 1;
  var w = wrap.clientWidth, h = wrap.clientHeight;
  canvas.width = w * dpr; canvas.height = h * dpr;
  canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
  var ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);
  ctx.clearRect(0, 0, w, h);

  var withWeight = registros.filter(function(r) { return typeof r.peso === 'number'; })
    .slice().sort(function(a, b) { return new Date(a.data) - new Date(b.data); });

  if (withWeight.length < 2) {
    ctx.fillStyle = '#686c78';
    ctx.font = '12.5px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('Registre ao menos 2 pesagens para ver o gráfico', w / 2, h / 2);
    return;
  }

  var weights = withWeight.map(function(r) { return r.peso; });
  var min = Math.min.apply(null, weights), max = Math.max.apply(null, weights);
  var pad = (max - min) * 0.18 || 1;
  min -= pad; max += pad;

  var padX = 8, padY = 16;
  var plotW = w - padX * 2, plotH = h - padY * 2;
  function xAt(i) { return padX + (plotW * i) / (withWeight.length - 1); }
  function yAt(v) { return padY + plotH - ((v - min) / (max - min)) * plotH; }

  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  for (var g = 0; g <= 2; g++) {
    var gy = padY + (plotH * g) / 2;
    ctx.beginPath(); ctx.moveTo(padX, gy); ctx.lineTo(w - padX, gy); ctx.stroke();
  }

  ctx.beginPath();
  withWeight.forEach(function(r, i) {
    var x = xAt(i), y = yAt(r.peso);
    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
  });
  ctx.shadowColor = 'rgba(57,255,158,0.5)'; ctx.shadowBlur = 8;
  ctx.strokeStyle = '#39ff9e'; ctx.lineWidth = 2.5; ctx.lineJoin = 'round'; ctx.stroke();
  ctx.shadowBlur = 0;

  var grad = ctx.createLinearGradient(0, padY, 0, padY + plotH);
  grad.addColorStop(0, 'rgba(232,162,58,0.16)');
  grad.addColorStop(1, 'rgba(232,162,58,0)');
  ctx.lineTo(xAt(withWeight.length - 1), padY + plotH);
  ctx.lineTo(xAt(0), padY + plotH);
  ctx.closePath(); ctx.fillStyle = grad; ctx.fill();

  withWeight.forEach(function(r, i) {
    var x = xAt(i), y = yAt(r.peso);
    ctx.beginPath();
    ctx.arc(x, y, i === withWeight.length - 1 ? 4 : 2.3, 0, Math.PI * 2);
    ctx.fillStyle = i === withWeight.length - 1 ? '#39ff9e' : '#2a9d6b';
    ctx.fill();
  });

  var last = withWeight[withWeight.length - 1];
  ctx.fillStyle = '#f5f5f7';
  ctx.font = '600 13px Inter, sans-serif';
  ctx.textAlign = 'right';
  var ly = yAt(last.peso);
  ctx.fillText(last.peso + ' kg', w - padX, ly - 12 < padY + 10 ? ly + 18 : ly - 10);
}

function renderRemedioPage() {
  var registros = getRegistros();
  var sorted = registros.slice().sort(function(a, b) { return new Date(a.data) - new Date(b.data); });
  var withWeight = sorted.filter(function(r) { return typeof r.peso === 'number'; });

  var statsEl = document.getElementById('med-stats');
  var totalAplicacoes = registros.length;
  var variacao = '—';
  var toneClass = '';
  if (withWeight.length >= 2) {
    var d = (withWeight[withWeight.length - 1].peso - withWeight[0].peso).toFixed(1);
    variacao = (d > 0 ? '+' : '') + d + ' kg';
    toneClass = d <= 0 ? 'tone-neon' : 'tone-coral';
  }
  statsEl.innerHTML =
    '<div class="stat-box"><p class="stat-label">' + ICONS.syringe + ' aplicações</p><p class="stat-value">' + totalAplicacoes + '</p></div>' +
    '<div class="stat-box"><p class="stat-label">' + ICONS.trend + ' variação total</p><p class="stat-value ' + toneClass + '">' + variacao + '</p></div>';

  var nextDoseInfo = getNextDoseInfo(sorted);
  document.getElementById('next-dose-row').innerHTML =
    '<div class="next-dose-icon">' + ICONS.calendar + '</div>' +
    '<div class="next-dose-text"><p>Próxima aplicação: ' + nextDoseInfo.label + '</p><p>' + nextDoseInfo.sub + '</p></div>';

  drawChart(registros);

  var ordenadosDesc = sorted.slice().reverse();
  var visibleList = showAllHistory ? ordenadosDesc : ordenadosDesc.slice(0, 5);
  var tl = document.getElementById('timeline');

  if (ordenadosDesc.length === 0) {
    tl.innerHTML = '<div class="empty-state">Nenhuma aplicação registrada ainda</div>';
  } else {
    tl.innerHTML = visibleList.map(function(r) {
      var idxInSorted = sorted.indexOf(r);
      var prevWithWeight = null;
      for (var i = idxInSorted - 1; i >= 0; i--) {
        if (typeof sorted[i].peso === 'number') { prevWithWeight = sorted[i]; break; }
      }
      var delta = '';
      if (typeof r.peso === 'number' && prevWithWeight) {
        var dd = (r.peso - prevWithWeight.peso).toFixed(1);
        delta = '<span class="t-delta' + (dd > 0 ? ' up' : '') + '">' + (dd > 0 ? '+' : '') + dd + '</span>';
      }
      var sideTags = '';
      if (r.sideEffects && r.sideEffects.length) {
        sideTags = '<div class="t-side-tags">' + r.sideEffects.map(function(s) { return '<span class="t-side-tag">' + s + '</span>'; }).join('') + '</div>';
      }
      var metaParts = [];
      if (r.site) metaParts.push(r.site);
      if (r.nota) metaParts.push(r.nota);
