var dayNamesFull = ['domingo','segunda','terça','quarta','quinta','sexta','sábado'];
var todayIdx = new Date().getDay();

// Nome completo do dia, com "-feira" apenas para dias de semana (seg a sex).
// Sábado e Domingo aparecem sozinhos, com inicial maiúscula.
function fullDayLabel(idx) {
  var name = dayNamesFull[idx];
  var withSuffix = (idx >= 1 && idx <= 5) ? name + '-feira' : name;
  return withSuffix.charAt(0).toUpperCase() + withSuffix.slice(1);
}
document.getElementById('today-chip').textContent = fullDayLabel(todayIdx);

// true para sábado (6) e domingo (0): não há treino planejado nesses dias.
function isRestDay() { return todayIdx === 0 || todayIdx === 6; }

function todayDayId() {
  var map = { 1: 'seg', 2: 'ter', 3: 'qua', 4: 'qui', 5: 'sex' };
  return map[todayIdx] || null;
}

/* ============ STORAGE ============ */
var LOG_KEY = 'treino_log_v2';
var REG_KEY = 'glp1_registros_v2';
var SESSIONS_KEY = 'treino_sessions_v1';
var MIGRATION_KEY = 'treino_migrado_v1';
var FOOD_KEY = 'alimentacao_log_v1';
var CHEAT_KEY = 'refeicao_livre_dias_v1';

function getLogs() { try { return JSON.parse(localStorage.getItem(LOG_KEY)) || {}; } catch (e) { return {}; } }
function saveLogs(l) { localStorage.setItem(LOG_KEY, JSON.stringify(l)); }
function getRegistros() { try { return JSON.parse(localStorage.getItem(REG_KEY)) || []; } catch (e) { return []; } }
function saveRegistros(r) { localStorage.setItem(REG_KEY, JSON.stringify(r)); }
function getSessions() { try { return JSON.parse(localStorage.getItem(SESSIONS_KEY)) || []; } catch (e) { return []; } }
function saveSessions(s) { localStorage.setItem(SESSIONS_KEY, JSON.stringify(s)); }
function getFoodLog() { try { return JSON.parse(localStorage.getItem(FOOD_KEY)) || []; } catch (e) { return []; } }
function saveFoodLog(f) { localStorage.setItem(FOOD_KEY, JSON.stringify(f)); }
function getCheatDays() { try { return JSON.parse(localStorage.getItem(CHEAT_KEY)) || []; } catch (e) { return []; } }
function saveCheatDays(c) { localStorage.setItem(CHEAT_KEY, JSON.stringify(c)); }

function isoToday() { return isoDate(new Date()); }
function isoDate(d) {
  var y = d.getFullYear(), m = ('0' + (d.getMonth() + 1)).slice(-2), day = ('0' + d.getDate()).slice(-2);
  return y + '-' + m + '-' + day;
}
function formatDateBR(iso) { var p = iso.split('-'); return p[2] + '/' + p[1] + '/' + p[0].slice(2); }
function daysBetween(a, b) { return Math.round((new Date(b) - new Date(a)) / 86400000); }

function isCheatDayToday() { return getCheatDays().indexOf(todayIdx) > -1; }

/* ---- Toggle de treino concluído: mantém o log semanal (compatível com o que já existia)
       e também grava/remove uma sessão datada, usada no Histórico de Treinos ---- */
function toggleTreinoDone(dayId, isoDateStr) {
  var logs = getLogs();
  var wk = getWeekKey();
  if (!logs[wk]) logs[wk] = {};
  var willBeDone = !logs[wk][dayId];
  logs[wk][dayId] = willBeDone;
  saveLogs(logs);

  var sessions = getSessions();
  if (willBeDone) {
    sessions.push({ id: Date.now().toString(), data: isoDateStr, dayId: dayId });
    saveSessions(sessions);
  } else {
    var filtered = sessions.filter(function(s) { return !(s.data === isoDateStr && s.dayId === dayId); });
    saveSessions(filtered);
  }
}

/* ---- Migração única: reconstrói sessões a partir do log semanal antigo (semanas já fechadas) ---- */
function weekStartFromKey(weekKey) {
  var parts = weekKey.split('-w');
  var year = parseInt(parts[0], 10), week = parseInt(parts[1], 10);
  var jan1 = new Date(year, 0, 1);
  var diffDays = (week - 1) * 7 - jan1.getDay();
  return new Date(year, 0, 1 + diffDays);
}
function migrateOldLogsToSessions() {
  if (localStorage.getItem(MIGRATION_KEY)) return;
  var logs = getLogs();
  var sessions = getSessions();
  var existingKeys = {};
  sessions.forEach(function(s) { existingKeys[s.data + '|' + s.dayId] = true; });
  Object.keys(logs).forEach(function(weekKey) {
    var weekLog = logs[weekKey];
    var sunday = weekStartFromKey(weekKey);
    Object.keys(weekLog).forEach(function(dayId) {
      if (!weekLog[dayId]) return;
      var offset = DAY_ID_TO_WEEKDAY[dayId];
      if (offset == null) return;
      var dt = new Date(sunday.getFullYear(), sunday.getMonth(), sunday.getDate() + offset);
      var iso = isoDate(dt);
      var key = iso + '|' + dayId;
      if (!existingKeys[key]) {
        sessions.push({ id: weekKey + '-' + dayId, data: iso, dayId: dayId });
        existingKeys[key] = true;
      }
    });
  });
  saveSessions(sessions);
  localStorage.setItem(MIGRATION_KEY, '1');
}

function showToast(text) {
  var toast = document.getElementById('toast');
  document.getElementById('toast-text').textContent = text;
  toast.classList.add('show');
  setTimeout(function() { toast.classList.remove('show'); }, 1800);
}

/* ============ NAVEGAÇÃO ============ */
var pages = ['home', 'treino', 'alimentacao', 'remedio'];
var navBtns = document.querySelectorAll('.bottomnav button');

function goToPage(page) {
  pages.forEach(function(p) {
    document.getElementById('page-' + p).classList.toggle('visible', p === page);
  });
  navBtns.forEach(function(b) {
    b.classList.toggle('active', b.getAttribute('data-page') === page);
  });
  var subs = { home: 'acompanhamento', treino: 'plano de treino', alimentacao: 'diário alimentar', remedio: 'controle de aplicação' };
  document.getElementById('header-sub').textContent = subs[page];
  if (page === 'treino') renderTreinoPage();
  if (page === 'alimentacao') renderAlimentacaoPage();
  if (page === 'remedio') renderRemedioPage();
  if (page === 'home') renderHomePage();
}
navBtns.forEach(function(b) {
  b.onclick = function() { goToPage(this.getAttribute('data-page')); };
});

