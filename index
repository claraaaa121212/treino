  renderCheatBanner();
  renderFoodLists();

  var entries = getFoodLog().slice().sort(function(a, b) { return new Date(b.data) - new Date(a.data); });
  var visibleList = showAllFoodHistory ? entries : entries.slice(0, 6);
  var tl = document.getElementById('food-timeline');
  if (entries.length === 0) {
    tl.innerHTML = '<div class="empty-state">Nenhuma refeição registrada ainda</div>';
  } else {
    tl.innerHTML = visibleList.map(function(f) {
      return '<div class="t-row"><div class="t-dot"></div><div class="t-body">' +
        '<div class="t-top"><span class="t-date">' + formatDateBR(f.data) + '</span><span class="meal-tag">' + f.refeicao + '</span></div>' +
        '<p class="t-meta">' + f.descricao + '</p>' +
        (f.nota ? '<p class="t-meta">' + f.nota + '</p>' : '') +
        '</div><div class="t-actions"><button class="t-edit" data-fid="' + f.id + '">' + ICONS.pencil + '</button><button class="t-del" data-fid="' + f.id + '">✕</button></div></div>';
    }).join('');
  }
  document.getElementById('btn-toggle-food-history').textContent = showAllFoodHistory ? 'recentes ▴' : 'tudo ▾';
  document.getElementById('btn-toggle-food-history').style.display = entries.length > 6 ? 'inline-block' : 'none';

  tl.querySelectorAll('.t-edit').forEach(function(btn) {
    btn.onclick = function() {
      var fid = this.getAttribute('data-fid');
      var f = getFoodLog().filter(function(x) { return x.id === fid; })[0];
      if (f) abrirSheetAlimentacao(f);
    };
  });
  tl.querySelectorAll('.t-del').forEach(function(btn) {
    btn.onclick = function() {
      var fid = this.getAttribute('data-fid');
      saveFoodLog(getFoodLog().filter(function(x) { return x.id !== fid; }));
      renderAlimentacaoPage();
    };
  });
}
document.getElementById('btn-toggle-food-history').onclick = function() {
  showAllFoodHistory = !showAllFoodHistory;
  renderAlimentacaoPage();
};

/* ---- SHEET: nova/editar refeição ---- */
var sheetOverlayAlimentacao = document.getElementById('sheet-overlay-alimentacao');
var editingFoodId = null;

function abrirSheetAlimentacao(entry) {
  editingFoodId = entry ? entry.id : null;
  document.getElementById('sheet-alimentacao-title').textContent = entry ? 'Editar refeição' : 'Registrar refeição';
  document.getElementById('btn-salvar-alimentacao').textContent = entry ? 'Salvar alterações' : 'Salvar refeição';
  document.getElementById('input-alimentacao-data').value = entry ? entry.data : isoToday();
  document.getElementById('input-alimentacao-refeicao').value = entry ? entry.refeicao : 'Café da manhã';
  document.getElementById('input-alimentacao-descricao').value = entry ? entry.descricao : '';
  document.getElementById('input-alimentacao-nota').value = entry && entry.nota ? entry.nota : '';
  sheetOverlayAlimentacao.classList.add('visible');
}
document.getElementById('btn-abrir-sheet-alimentacao').onclick = function() { abrirSheetAlimentacao(null); };
document.getElementById('btn-cancelar-alimentacao').onclick = function() { sheetOverlayAlimentacao.classList.remove('visible'); };
sheetOverlayAlimentacao.onclick = function(e) { if (e.target === sheetOverlayAlimentacao) sheetOverlayAlimentacao.classList.remove('visible'); };

document.getElementById('btn-salvar-alimentacao').onclick = function() {
  var data = document.getElementById('input-alimentacao-data').value;
  var refeicao = document.getElementById('input-alimentacao-refeicao').value;
  var descricao = document.getElementById('input-alimentacao-descricao').value.trim();
  var nota = document.getElementById('input-alimentacao-nota').value.trim();
  if (!data || !descricao) return;

  var entries = getFoodLog();
  if (editingFoodId) {
    var idx = entries.findIndex(function(e) { return e.id === editingFoodId; });
    if (idx > -1) {
      entries[idx] = { id: editingFoodId, data: data, refeicao: refeicao, descricao: descricao };
      if (nota) entries[idx].nota = nota;
    }
    showToast('Refeição atualizada');
  } else {
    var entry = { id: Date.now().toString(), data: data, refeicao: refeicao, descricao: descricao };
    if (nota) entry.nota = nota;
    entries.push(entry);
    showToast('Refeição registrada');
  }
  saveFoodLog(entries);
  editingFoodId = null;
  sheetOverlayAlimentacao.classList.remove('visible');
  renderAlimentacaoPage();
};

/* ---- SHEET: configurar refeição livre ---- */
var sheetOverlayCheatdays = document.getElementById('sheet-overlay-cheatdays');
var selectedCheatDays = [];

document.getElementById('btn-abrir-cheatdays').onclick = function() {
  selectedCheatDays = getCheatDays().slice();
  document.querySelectorAll('#cheatdays-grid .wd-btn').forEach(function(b) {
    b.classList.toggle('active', selectedCheatDays.indexOf(parseInt(b.getAttribute('data-wd'), 10)) > -1);
  });
  sheetOverlayCheatdays.classList.add('visible');
};
document.querySelectorAll('#cheatdays-grid .wd-btn').forEach(function(btn) {
  btn.onclick = function() {
    var wd = parseInt(this.getAttribute('data-wd'), 10);
    var idx = selectedCheatDays.indexOf(wd);
    if (idx > -1) { selectedCheatDays.splice(idx, 1); this.classList.remove('active'); }
    else { selectedCheatDays.push(wd); this.classList.add('active'); }
  };
});
document.getElementById('btn-cancelar-cheatdays').onclick = function() { sheetOverlayCheatdays.classList.remove('visible'); };
sheetOverlayCheatdays.onclick = function(e) { if (e.target === sheetOverlayCheatdays) sheetOverlayCheatdays.classList.remove('visible'); };
document.getElementById('btn-salvar-cheatdays').onclick = function() {
  saveCheatDays(selectedCheatDays.slice());
  sheetOverlayCheatdays.classList.remove('visible');
  showToast('Refeição livre atualizada');
  renderCheatBanner();
  renderHomePage();
};

/* ============ MIGRAÇÃO E RENDER INICIAL DOS NOVOS MÓDULOS ============ */
migrateOldLogsToSessions();
renderFoodLists();
</script>

