  editingSessionId = session ? session.id : null;
  document.getElementById('sheet-treino-title').textContent = session ? 'Editar treino' : 'Registrar treino';
  document.getElementById('btn-salvar-treino').textContent = session ? 'Salvar alterações' : 'Salvar treino';
