  // hero: peso atual + variação
  if (registros.length > 0) {
    var first = registros[0].peso;
    var last = registros[registros.length - 1];
    var hasPeso = typeof last.peso === 'number';
    if (hasPeso) {
      var diff = (last.peso - first).toFixed(1);
      html += '<div class="hero-stat">' +
        '<p class="eyebrow">peso atual</p>' +
        '<p class="big">' + last.peso + '<small> kg</small></p>' +
        '<p class="sub">' + (diff <= 0 ? '↓ ' : '↑ ') + Math.abs(diff) + ' kg desde o início do registro</p>' +
      '</div>';
    }
  } else {
    html += '<div class="hero-stat"><p class="eyebrow">peso atual</p><p class="big">—</p><p class="sub">registre sua primeira aplicação para começar</p></div>';
  }

  // stats grid: treinos na semana + próxima dose
  var weekKey = getWeekKey();
  var weekLog = logs[weekKey] || {};
  var doneCount = 0;
  for (var k in weekLog) if (weekLog[k]) doneCount++;

  var nextDoseInfo = getNextDoseInfo(registros);

  html += '<div class="stat-grid">' +
    '<div class="stat-box"><p class="stat-label">' + ICONS.flame + ' treinos na semana</p><p class="stat-value">' + doneCount + '<span style="font-size:13px; color:var(--ink-faint);">/5</span></p></div>' +
    '<div class="stat-box"><p class="stat-label">' + ICONS.syringe + ' próxima dose</p><p class="stat-value' + (nextDoseInfo.urgent ? ' tone-coral' : '') + '">' + nextDoseInfo.label + '</p><p class="stat-foot">' + nextDoseInfo.sub + '</p></div>' +
  '</div>';

  // treino de hoje
  if (isRestDay()) {
    html += '<p class="section-title">Treino de hoje</p>' +
      '<div class="info-banner" style="background:var(--bg-elev-2); color:var(--ink);">' +
        '<div class="ib-icon" style="background:var(--bg-elev-3);">' + ICONS.moon + '</div>' +
        '<div><h3>Dia de descanso</h3><p>' + fullDayLabel(todayIdx) + ' não tem treino programado. Aproveite para recuperar.</p></div>' +
      '</div>';
  } else {
    var todayDay = DAYS.filter(function(d) { return d.id === todayDayId(); })[0];
    if (todayDay) {
      var tone = TONES[todayDay.tone];
      var doneToday = !!weekLog[todayDay.id];
      html += '<p class="section-title">Treino de hoje</p>' +
        '<div class="day-banner' + (doneToday ? ' logged' : '') + '" style="background:' + tone.bg + '; color:' + tone.fg + ';">' +
          '<svg class="glyph" viewBox="0 0 24 24" fill="none" stroke="' + tone.fg + '" stroke-width="1.6" stroke-linecap="round"><path d="' + todayDay.icon + '"/></svg>' +
          '<p class="eyebrow">' + fullDayLabel(todayIdx) + '</p>' +
          '<h2>' + todayDay.title + '</h2>' +
          '<p class="meta">' + todayDay.exercises.length + ' exercícios</p>' +
          '<button class="complete-btn" id="home-toggle-done">' + (doneToday ? ICONS.check + ' Concluído' : 'Marcar como feito') + '</button>' +
        '</div>';
    }
  }

  // refeição livre hoje
  if (isCheatDayToday()) {
    html += '<div class="info-banner" style="background:var(--violet-soft); color:var(--violet); border-color:rgba(157,127,255,0.3); margin-top:-4px;">' +
        '<div class="ib-icon" style="background:rgba(157,127,255,0.14); border:1px solid rgba(157,127,255,0.25);">' + ICONS.fork + '</div>' +
        '<div><h3>Hoje é refeição livre</h3><p>Aproveite com equilíbrio — sem culpa.</p></div>' +
      '</div>';
  }

  home.innerHTML = html;

  var toggleBtn = document.getElementById('home-toggle-done');
  if (toggleBtn) {
    toggleBtn.onclick = function() {
      var dayId = todayDayId();
