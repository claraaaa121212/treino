  var html = '<p class="t-meta" style="margin-bottom:8px;">' + formatDateBR(calSelectedDate) + '</p>';
  if (sessions.length === 0) {
    html += '<button class="btn-ghost" id="btn-add-session-dia" style="width:100%;">+ Registrar treino neste dia</button>';
  } else {
    html += sessions.map(function(s) {
      var day = DAYS.filter(function(d) { return d.id === s.dayId; })[0];
      return '<div class="t-row"><div class="t-dot"></div><div class="t-body"><div class="t-top"><span class="t-date">' + (day ? day.title : s.dayId) + '</span></div>' +
        (s.nota ? '<p class="t-meta">' + s.nota + '</p>' : '') + '</div>' +
        '<div class="t-actions"><button class="t-edit" data-sid="' + s.id + '">' + ICONS.pencil + '</button><button class="t-del" data-sid="' + s.id + '">✕</button></div></div>';
    }).join('');
  }
  panel.innerHTML = html;

  var addBtn = document.getElementById('btn-add-session-dia');
  if (addBtn) addBtn.onclick = function() { abrirSheetTreino(null, calSelectedDate); };

  panel.querySelectorAll('.t-edit').forEach(function(btn) {
