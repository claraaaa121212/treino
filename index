function drawFreqChart(sessions) {
  var canvas = document.getElementById('freq-chart');
  var wrap = canvas.parentElement;
  var dpr = window.devicePixelRatio || 1;
  var w = wrap.clientWidth, h = wrap.clientHeight;
  canvas.width = w * dpr; canvas.height = h * dpr;
  canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
  var ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);
  ctx.clearRect(0, 0, w, h);

  var weeks = [];
  var thisWeekStart = weekStartDate();
  for (var i = 7; i >= 0; i--) {
    var start = new Date(thisWeekStart.getFullYear(), thisWeekStart.getMonth(), thisWeekStart.getDate() - i * 7);
    var end = new Date(start.getFullYear(), start.getMonth(), start.getDate() + 6);
    var count = sessions.filter(function(s) {
      var d = new Date(s.data + 'T00:00:00');
      return d >= start && d <= end;
    }).length;
    weeks.push({ label: ('0' + (start.getMonth() + 1)).slice(-2) + '/' + ('0' + start.getDate()).slice(-2), count: count });
  }

  var padX = 8, padY = 16, padBottom = 18;
  var plotW = w - padX * 2, plotH = h - padY - padBottom;
  var maxCount = Math.max(5, Math.max.apply(null, weeks.map(function(x) { return x.count; })));
  var barW = (plotW / weeks.length) * 0.55;
  var step = plotW / weeks.length;

  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  for (var g = 0; g <= 2; g++) {
    var gy = padY + (plotH * g) / 2;
    ctx.beginPath(); ctx.moveTo(padX, gy); ctx.lineTo(w - padX, gy); ctx.stroke();
  }

  weeks.forEach(function(wkData, idx) {
    var bx = padX + step * idx + (step - barW) / 2;
    var bh = (wkData.count / maxCount) * plotH;
    var by = padY + plotH - bh;
    var isLast = idx === weeks.length - 1;
    ctx.fillStyle = isLast ? '#39ff9e' : 'rgba(57,255,158,0.35)';
    if (bh > 0) {
      ctx.beginPath();
      ctx.roundRect ? ctx.roundRect(bx, by, barW, bh, 4) : ctx.rect(bx, by, barW, bh);
      ctx.fill();
    }
    ctx.fillStyle = '#686c78';
    ctx.font = '9px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(wkData.label, bx + barW / 2, h - 4);
  });
}

var showAllTreinoHistory = false;

function renderHistoricoTreino() {
  var sessions = getSessions().slice().sort(function(a, b) { return new Date(b.data) - new Date(a.data); });
  var stats = computeTreinoStats(sessions);

  document.getElementById('treino-stats').innerHTML =
    '<div class="stat-box"><p class="stat-label">' + ICONS.calendar + ' esta semana</p><p class="stat-value">' + stats.weekCount + '<span style="font-size:13px; color:var(--ink-faint);">/5</span></p></div>' +
    '<div class="stat-box"><p class="stat-label">' + ICONS.calendar + ' este mês</p><p class="stat-value">' + stats.monthCount + '</p></div>' +
    '<div class="stat-box"><p class="stat-label">' + ICONS.flame + ' sequência</p><p class="stat-value">' + stats.streak + '<span style="font-size:13px; color:var(--ink-faint);">d</span></p></div>' +
    '<div class="stat-box"><p class="stat-label">' + ICONS.trend + ' total</p><p class="stat-value">' + stats.total + '</p></div>';

  renderCalendar();
  renderCalDayPanel();

  var visibleList = showAllTreinoHistory ? sessions : sessions.slice(0, 5);
  var tl = document.getElementById('treino-timeline');
  if (sessions.length === 0) {
    tl.innerHTML = '<div class="empty-state">Nenhum treino registrado ainda</div>';
  } else {
    tl.innerHTML = visibleList.map(function(s) {
      var day = DAYS.filter(function(d) { return d.id === s.dayId; })[0];
      return '<div class="t-row"><div class="t-dot"></div><div class="t-body"><div class="t-top">' +
        '<span class="t-date">' + formatDateBR(s.data) + '</span>' +
        '<span class="t-dose-tag">' + (day ? day.title : s.dayId) + '</span>' +
        '</div>' + (s.nota ? '<p class="t-meta">' + s.nota + '</p>' : '') + '</div>' +
        '<div class="t-actions"><button class="t-edit" data-sid="' + s.id + '">' + ICONS.pencil + '</button><button class="t-del" data-sid="' + s.id + '">✕</button></div></div>';
    }).join('');
  }
  document.getElementById('btn-toggle-treino-history').textContent = showAllTreinoHistory ? 'recentes ▴' : 'tudo ▾';
  document.getElementById('btn-toggle-treino-history').style.display = sessions.length > 5 ? 'inline-block' : 'none';

  tl.querySelectorAll('.t-edit').forEach(function(btn) {
    btn.onclick = function() {
      var sid = this.getAttribute('data-sid');
      var s = getSessions().filter(function(x) { return x.id === sid; })[0];
      if (s) abrirSheetTreino(s);
    };
  });
  tl.querySelectorAll('.t-del').forEach(function(btn) {
    btn.onclick = function() {
      var sid = this.getAttribute('data-sid');
      saveSessions(getSessions().filter(function(x) { return x.id !== sid; }));
      renderHistoricoTreino();
    };
  });

  try { drawFreqChart(sessions); } catch (e) { /* gráfico é apenas visual; não deve travar o restante da tela */ }
}
document.getElementById('btn-toggle-treino-history').onclick = function() {
  showAllTreinoHistory = !showAllTreinoHistory;
  renderHistoricoTreino();
};
window.addEventListener('resize', function() {
  if (document.getElementById('treino-tab-historico').style.display !== 'none' &&
      document.getElementById('page-treino').classList.contains('visible')) {
    drawFreqChart(getSessions());
  }
});

